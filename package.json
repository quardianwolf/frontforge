{
  "name": "@atilladev/frontforge",
  "version": "0.1.0",
  "description": "MCP server for scaffolding Next.js & Expo/React Native projects with Atomic Design, React Query, and TypeScript",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "frontforge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/"
  },
  "keywords": [
    "mcp",
    "frontend",
    "nextjs",
    "expo",
    "react-native",
    "atomic-design",
    "scaffold",
    "cli"
  ],
  "author": "quardianwolf",
  "repository": {
    "type": "git",
    "url": "https://github.com/quardianwolf/frontforge.git"
  },
  "homepage": "https://github.com/quardianwolf/frontforge#readme",
  "bugs": {
    "url": "https://github.com/quardianwolf/frontforge/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
